# ==========================================================
# AI Incoming Voice Bot - Environment Configuration
# Copy this file to .env and fill in the values
# ==========================================================

# ---- Server ----
PORT=3000

# ---- AI Provider ----
# Choose one: gemini | groq | auto (auto rotates/fails over across both)
API_PROVIDER=gemini

# Google Gemini (free tier) - https://aistudio.google.com/app/apikey
# You can provide multiple comma-separated keys for round-robin rotation & automatic failover
GEMINI_API_KEYS=key1,key2
GEMINI_MODEL=gemini-2.5-flash

# Groq (free tier) - https://console.groq.com/keys
# You can provide multiple comma-separated keys for round-robin rotation & automatic failover
GROQ_API_KEYS=key1,key2
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Speech-to-Text (Whisper) ----
# Engine: whispercpp | fasterwhisper
STT_ENGINE=whispercpp

# Path to whisper.cpp binary (built locally, free/open-source)
WHISPER_CPP_BIN=./bin/whisper.cpp/main
WHISPER_CPP_MODEL=./bin/whisper.cpp/models/ggml-medium.bin

# Path to faster-whisper python launcher script (if using fasterwhisper engine)
FASTER_WHISPER_SCRIPT=./backend/scripts/faster_whisper_transcribe.py
FASTER_WHISPER_MODEL=medium
FASTER_WHISPER_DEVICE=cpu

# Language hint for STT (hi = Hindi, handles Hinglish reasonably well)
STT_LANGUAGE=hi

# ---- Text-to-Speech (Piper) ----
TTS_ENGINE=piper
PIPER_BIN=./bin/piper/piper
PIPER_VOICE_MODEL=./bin/piper/voices/hi_IN-pratham-medium.onnx
VOICE=hi-IN

# ---- Database ----
SQLITE_DB_PATH=./database/voicebot.db

# ---- Logging ----
LOG_LEVEL=info
LOG_FILE=./logs/calls.log

# ---- Telephony / Media Bridge ----
# This project only handles the AI pipeline over WebSocket audio frames.
# To connect real PSTN incoming calls, bridge a SIP/PBX (e.g. Asterisk or
# FreeSWITCH, both free & open-source) to this WebSocket endpoint.
# See README.md "Telephony Integration" section for details.
WS_PATH=/media-stream
